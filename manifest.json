{
  "manifest_version": 3,
  "name": "PromptPilot",
  "description": "Generate and autofill context-aware prompts for testing AI tools, building overseas AI sites, and running prompt workflows.",
  "version": "0.1.0",
  "action": {
    "default_title": "PromptPilot",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "fill-last-prompt": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "Fill the last used prompt into the current input"
    }
  },
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": [
    "<all_urls>",
    "https://api.openai.com/*",
    "https://api.mimo-v2.com/*",
    "https://token-plan-cn.xiaomimimo.com/*"
  ]
}
